                            <select id="demo-difficulty" class="w-full border border-gray-300 rounded-lg px-3 py-2 touch-target">
                                <option value="easy">简单</option>
                                <option value="medium">中等</option>
                                <option value="hard">困难</option>
                                <option value="expert">挑战</option>
                            </select>
                        </div>
                    </div>
                    <div class="flex flex-col sm:flex-row gap-3">
                        <button id="load-demo" class="bg-green-400 hover:bg-green-500 text-white px-6 py-3 rounded-2xl transition font-bold touch-target w-full sm:w-auto text-base shadow-md" aria-label="使用演示图片">
                            使用演示图片
                        </button>
                        <button id="reset-demo" class="bg-gray-400 hover:bg-gray-500 text-white px-6 py-3 rounded-2xl transition font-bold touch-target w-full sm:w-auto text-base shadow-md" aria-label="重置">
                            重置
                        </button>
                    </div>
                </div>
            </section>
            
            <!-- 家庭卫生管理 -->
            <section class="mb-6 md:mb-8" aria-labelledby="cleaning-history-heading">
                <h2 id="cleaning-history-heading" class="text-xl md:text-2xl font-bold mb-4 text-gray-800">家庭卫生管理</h2>
                
                <!-- 卫生记录 -->
                <div class="mb-6">
                    <h3 class="text-lg font-semibold mb-3 text-gray-700">卫生记录</h3>
                    <div class="border-2 border-gray-200 rounded-lg p-4">
                        <div class="flex flex-col sm:flex-row gap-4 mb-4">
                            <div class="flex-1">
                                <label class="block text-sm font-medium text-gray-700 mb-2">日期范围</label>
                                <div class="flex space-x-2">
                                    <input type="date" id="date-from" class="w-full border border-gray-300 rounded-lg px-3 py-2 touch-target">
                                    <input type="date" id="date-to" class="w-full border border-gray-300 rounded-lg px-3 py-2 touch-target">
                                </div>
                            </div>
                            <div class="flex-1">
                                <label class="block text-sm font-medium text-gray-700 mb-2">房间类型</label>
                                <select id="history-room" class="w-full border border-gray-300 rounded-lg px-3 py-2 touch-target">
                                    <option value="all">全部</option>
                                    <option value="bedroom">卧室</option>
                                    <option value="living-room">客厅</option>
                                    <option value="bathroom">卫生间</option>
                                    <option value="kitchen">厨房</option>
                                    <option value="study">书房</option>
                                    <option value="balcony">阳台</option>
                                </select>
                            </div>
                            <div class="flex-1">
                                <label class="block text-sm font-medium text-gray-700 mb-2">成员</label>
                                <select id="history-user" class="w-full border border-gray-300 rounded-lg px-3 py-2 touch-target">
                                    <option value="all">全部</option>
                                    <option value="default">我</option>
                                </select>
                            </div>
                        </div>
                        <button id="filter-history" class="bg-blue-400 hover:bg-blue-500 text-white px-6 py-3 rounded-2xl transition font-bold touch-target w-full md:w-auto text-base shadow-md mb-4" aria-label="筛选记录">
                            筛选记录
                        </button>
                        <div id="cleaning-history-list" class="max-h-64 overflow-y-auto border border-gray-200 rounded-lg p-4">
                            <!-- 记录将通过JavaScript动态生成 -->
                            <div class="text-center text-gray-500 py-4">
                                <p>暂无清洁记录</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- 数据统计分析 -->
                <div class="mb-6">
                    <h3 class="text-lg font-semibold mb-3 text-gray-700">数据统计分析</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="border-2 border-gray-200 rounded-lg p-4">
                            <h4 class="font-medium mb-3 text-gray-700">清洁频率统计</h4>
                            <div class="h-64">
                                <canvas id="frequency-chart"></canvas>
                            </div>
                        </div>
                        <div class="border-2 border-gray-200 rounded-lg p-4">
                            <h4 class="font-medium mb-3 text-gray-700">清洁时长统计</h4>
                            <div class="h-64">
                                <canvas id="duration-chart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- 互动激励机制 -->
                <div class="mb-6">
                    <h3 class="text-lg font-semibold mb-3 text-gray-700">互动激励</h3>
                    <div class="border-2 border-gray-200 rounded-lg p-4">
                        <div class="flex flex-col sm:flex-row gap-4 mb-4">
                            <div class="flex-1">
                                <label class="block text-sm font-medium text-gray-700 mb-2">选择成员</label>
                                <select id="praise-user" class="w-full border border-gray-300 rounded-lg px-3 py-2 touch-target">
                                    <option value="default">我</option>
                                </select>
                            </div>
                            <div class="flex-1">
                                <label class="block text-sm font-medium text-gray-700 mb-2">表扬内容</label>
                                <select id="praise-content" class="w-full border border-gray-300 rounded-lg px-3 py-2 touch-target">
                                    <option value="clean">打扫得真干净！</option>
                                    <option value="fast">速度真快！</option>
                                    <option value="thorough">打扫得真仔细！</option>
                                    <option value="creative">方法真有创意！</option>
                                </select>
                            </div>
                        </div>
                        <button id="send-praise" class="bg-green-400 hover:bg-green-500 text-white px-6 py-3 rounded-2xl transition font-bold touch-target w-full md:w-auto text-base shadow-md" aria-label="发送表扬">
                            发送表扬
                        </button>
                        <div id="praise-list" class="mt-4 max-h-40 overflow-y-auto border border-gray-200 rounded-lg p-4">
                            <!-- 表扬记录将通过JavaScript动态生成 -->
