                                <p>暂无表扬记录</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            
            <!-- 社交分享系统 -->
            <section class="mb-6 md:mb-8" aria-labelledby="social-heading">
                <h2 id="social-heading" class="text-xl md:text-2xl font-bold mb-4 text-gray-800">社交分享</h2>
                <div class="border-2 border-gray-200 rounded-lg p-4">
                    <div class="mb-4">
                        <h3 class="text-lg font-semibold mb-3 text-gray-700">分享清洁成果</h3>
                        <div class="flex flex-wrap gap-3">
                            <button id="share-wechat" class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg transition touch-target flex items-center" aria-label="分享到微信">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                                </svg>
                                微信
                            </button>
                            <button id="share-weibo" class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg transition touch-target flex items-center" aria-label="分享到微博">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                                微博
                            </button>
                            <button id="share-qq" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition touch-target flex items-center" aria-label="分享到QQ">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                QQ
                            </button>
                            <button id="share-copy" class="bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg transition touch-target flex items-center" aria-label="复制链接">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                </svg>
                                复制链接
                            </button>
                        </div>
                    </div>
                    <div class="mb-4">
                        <h3 class="text-lg font-semibold mb-3 text-gray-700">清洁挑战</h3>
                        <div class="border border-gray-200 rounded-lg p-4">
                            <div class="flex justify-between items-center mb-3">
                                <h4 class="font-medium">7天清洁挑战</h4>
                                <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded-full text-xs">进行中</span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-2.5 mb-3">
                                <div class="bg-blue-600 h-2.5 rounded-full" style="width: 42%"></div>
                            </div>
                            <p class="text-sm text-gray-600">已完成 3/7 天</p>
                            <button class="mt-3 bg-blue-400 hover:bg-blue-500 text-white px-4 py-2 rounded-lg transition touch-target w-full" aria-label="查看挑战详情">
                                查看挑战详情
                            </button>
                        </div>
                    </div>
                </div>
            </section>
        </div>
        
        <!-- 右侧勇者面板 -->
        <div class="w-full lg:w-1/4 space-y-6 md:space-y-8">
            <!-- 勇者信息 -->
            <div class="bg-white bg-opacity-90 rounded-xl shadow-xl p-4 md:p-6">
                <h2 class="text-xl md:text-2xl font-bold mb-4 text-gray-800">勇者信息</h2>
                <div class="flex flex-col items-center text-center mb-4">
                    <div class="w-24 h-24 bg-gradient-to-br from-pink-400 to-purple-400 rounded-full flex items-center justify-center mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
