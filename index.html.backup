    </main>
    
    <!-- 底部信息 -->
    <footer class="bg-gradient-to-r from-pink-400 to-purple-400 text-white py-4 md:py-6" role="contentinfo">
        <div class="container mx-auto px-4 text-center">
            <p class="text-sm md:text-base mb-2">家务勇者 V2.0.0 - 把家务变成游戏闯关</p>
            <p class="text-xs md:text-sm opacity-80">让孩子爱上做家务，让家庭更和谐</p>
        </div>
    </footer>
    
    <!-- 家庭成员管理模态框 -->
    <div id="family-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden" aria-hidden="true">
        <div class="bg-white rounded-xl shadow-2xl p-6 w-full max-w-md">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-bold text-gray-800">家庭成员管理</h2>
                <button id="close-family-modal" class="text-gray-500 hover:text-gray-700" aria-label="关闭">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">添加成员</label>
                <div class="flex space-x-2">
                    <input type="text" id="new-member-name" class="flex-1 border border-gray-300 rounded-lg px-3 py-2 touch-target" placeholder="成员姓名">
                    <button id="add-member" class="bg-blue-400 hover:bg-blue-500 text-white px-4 py-2 rounded-lg transition touch-target" aria-label="添加成员">
                        添加
                    </button>
                </div>
            </div>
            <div id="family-members-list" class="max-h-64 overflow-y-auto border border-gray-200 rounded-lg p-4 mb-4">
                <!-- 成员列表将通过JavaScript动态生成 -->
                <div class="text-center text-gray-500 py-4">
                    <p>暂无成员</p>
                </div>
            </div>
            <button id="save-family" class="bg-green-400 hover:bg-green-500 text-white px-6 py-3 rounded-2xl transition font-bold touch-target w-full text-base shadow-md" aria-label="保存家庭成员">
                保存
            </button>
        </div>
    </div>
    
    <!-- 家庭排行榜模态框 -->
    <div id="leaderboard-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden" aria-hidden="true">
        <div class="bg-white rounded-xl shadow-2xl p-6 w-full max-w-md">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-bold text-gray-800">家庭排行榜</h2>
                <button id="close-leaderboard-modal" class="text-gray-500 hover:text-gray-700" aria-label="关闭">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div id="leaderboard-list" class="max-h-64 overflow-y-auto border border-gray-200 rounded-lg p-4 mb-4">
                <!-- 排行榜将通过JavaScript动态生成 -->
                <div class="text-center text-gray-500 py-4">
                    <p>暂无排行数据</p>
                </div>
            </div>
            <button id="close-leaderboard" class="bg-gray-400 hover:bg-gray-500 text-white px-6 py-3 rounded-2xl transition font-bold touch-target w-full text-base shadow-md" aria-label="关闭排行榜">
                关闭
            </button>
        </div>
    </div>
    
    <!-- 任务分配模态框 -->
    <div id="assign-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden" aria-hidden="true">
        <div class="bg-white rounded-xl shadow-2xl p-6 w-full max-w-md">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-bold text-gray-800">分配任务</h2>
                <button id="close-assign-modal" class="text-gray-500 hover:text-gray-700" aria-label="关闭">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">选择成员</label>
                <select id="assign-member" class="w-full border border-gray-300 rounded-lg px-3 py-2 touch-target">
                    <option value="default">我</option>
                </select>
            </div>
            <div class="flex space-x-2">
                <button id="assign-task" class="flex-1 bg-blue-400 hover:bg-blue-500 text-white px-4 py-2 rounded-lg transition touch-target" aria-label="分配任务">
                    分配
                </button>
                <button id="unassign-task" class="flex-1 bg-gray-400 hover:bg-gray-500 text-white px-4 py-2 rounded-lg transition touch-target" aria-label="取消分配">
                    取消分配
                </button>
            </div>
        </div>
    </div>
    
    <!-- JavaScript -->
    <script>
        // 全局变量
        let currentUser = 'default';
        let currentGender = 'female';
        let familyMembers = [{ id: 'default', name: '我', contribution: 0, level: 1, experience: 0 }];
        let cleaningHistory = [];
        let praiseRecords = [];
        let equipment = {
            head: null,
            body: null,
            hands: null,
            feet: null
        };
        let achievements = [
            { id: 1, name: '初次清洁', description: '完成第一次清洁任务', unlocked: false, progress: 0, target: 1 },
            { id: 2, name: '清洁达人', description: '完成10次清洁任务', unlocked: false, progress: 0, target: 10 },
            { id: 3, name: '完美清洁', description: '获得10次AI满分评价', unlocked: false, progress: 0, target: 10 },
            { id: 4, name: '家庭卫士', description: '所有家庭成员完成清洁任务', unlocked: false, progress: 0, target: 1 }
        ];
        let skills = [
            { id: 1, name: '快速清洁', description: '清洁速度 +10%', unlocked: true, level: 1, maxLevel: 5 },
            { id: 2, name: '深度清洁', description: '清洁效果 +15%', unlocked: false, level: 0, maxLevel: 5 },
            { id: 3, name: '经验提升', description: '经验获取 +20%', unlocked: false, level: 0, maxLevel: 5 }
        ];
        
        // 初始化
        document.addEventListener('DOMContentLoaded', function() {
            initializeApp();
            setupEventListeners();
            updateUI();
        });
        
        // 初始化应用
        function initializeApp() {
            // 加载本地存储数据
            loadFromLocalStorage();
            
            // 初始化图表
            initializeCharts();
            
            // 生成智能任务推荐
            generateTaskRecommendations();
        }
        
        // 设置事件监听器
        function setupEventListeners() {
            // 性别选择
            document.querySelectorAll('.gender-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.gender-btn').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    currentGender = this.id.split('-')[1];
                    updateUI();
                });
            });
            
            // 用户下拉菜单
            document.getElementById('user-dropdown').addEventListener('change', function() {
                currentUser = this.value;
                updateUI();
            });
            
            // 家庭成员管理
            document.getElementById('family-management').addEventListener('click', function() {
                openFamilyModal();
            });
            
            // 家庭排行榜
            document.getElementById('family-leaderboard').addEventListener('click', function() {
                openLeaderboardModal();
            });
            
            // 任务卡片点击
            document.querySelectorAll('.hero-card').forEach(card => {
                card.addEventListener('click', function() {
                    selectTask(this);
                });
                
                // 右键点击分配任务
                card.addEventListener('contextmenu', function(e) {
                    e.preventDefault();
                    openAssignModal(this);
                });
            });
            
            // 图片上传
            document.getElementById('before-upload').addEventListener('change', function(e) {
                handleImageUpload(e, 'before');
            });
            
            document.getElementById('after-upload').addEventListener('change', function(e) {
                handleImageUpload(e, 'after');
            });
            
            // 生成对比图
            document.getElementById('generate-compare').addEventListener('click', function() {
                generateCompare();
            });
            
            // AI识别
            document.getElementById('ai-identify').addEventListener('click', function() {
                aiIdentify();
            });
            
            // 保存布局配置
            document.getElementById('save-layout').addEventListener('click', function() {
                saveLayout();
            });
            
            // 演示模式
            document.getElementById('load-demo').addEventListener('click', function() {
                loadDemoImages();
            });
            
            document.getElementById('reset-demo').addEventListener('click', function() {
                resetDemo();
            });
            
            // 筛选历史记录
            document.getElementById('filter-history').addEventListener('click', function() {
                filterHistory();
            });
            
            // 发送表扬
            document.getElementById('send-praise').addEventListener('click', function() {
                sendPraise();
            });
            
            // 社交分享
            document.getElementById('share-wechat').addEventListener('click', function() {
                shareTo('wechat');
            });
            
            document.getElementById('share-weibo').addEventListener('click', function() {
                shareTo('weibo');
            });
            
            document.getElementById('share-qq').addEventListener('click', function() {
                shareTo('qq');
            });
            
            document.getElementById('share-copy').addEventListener('click', function() {
                copyLink();
            });
            
            // 模态框关闭
            document.getElementById('close-family-modal').addEventListener('click', function() {
                closeFamilyModal();
            });
            
            document.getElementById('close-leaderboard-modal').addEventListener('click', function() {
                closeLeaderboardModal();
            });
            
            document.getElementById('close-assign-modal').addEventListener('click', function() {
                closeAssignModal();
            });
            
            // 添加成员
            document.getElementById('add-member').addEventListener('click', function() {
                addFamilyMember();
            });
            
            // 保存家庭成员
            document.getElementById('save-family').addEventListener('click', function() {
                saveFamilyMembers();
            });
            
            // 分配任务
            document.getElementById('assign-task').addEventListener('click', function() {
                assignTask();
            });
            
            // 取消分配
            document.getElementById('unassign-task').addEventListener('click', function() {
                unassignTask();
            });
        }
        
        // 加载本地存储数据
        function loadFromLocalStorage() {
            const savedMembers = localStorage.getItem('familyMembers');
            const savedHistory = localStorage.getItem('cleaningHistory');
            const savedPraise = localStorage.getItem('praiseRecords');
            const savedEquipment = localStorage.getItem('equipment');
            const savedAchievements = localStorage.getItem('achievements');
            const savedSkills = localStorage.getItem('skills');
            
            if (savedMembers) {
                familyMembers = JSON.parse(savedMembers);
            }
            
            if (savedHistory) {
                cleaningHistory = JSON.parse(savedHistory);
            }
            
            if (savedPraise) {
                praiseRecords = JSON.parse(savedPraise);
            }
            
            if (savedEquipment) {
                equipment = JSON.parse(savedEquipment);
            }
            
            if (savedAchievements) {
                achievements = JSON.parse(savedAchievements);
            }
            
            if (savedSkills) {
                skills = JSON.parse(savedSkills);
            }
            
            // 更新用户下拉菜单
            updateUserDropdown();
        }
        
        // 保存到本地存储
        function saveToLocalStorage() {
            localStorage.setItem('familyMembers', JSON.stringify(familyMembers));
            localStorage.setItem('cleaningHistory', JSON.stringify(cleaningHistory));
            localStorage.setItem('praiseRecords', JSON.stringify(praiseRecords));
            localStorage.setItem('equipment', JSON.stringify(equipment));
            localStorage.setItem('achievements', JSON.stringify(achievements));
            localStorage.setItem('skills', JSON.stringify(skills));
        }
        
        // 更新用户下拉菜单
        function updateUserDropdown() {
            const dropdown = document.getElementById('user-dropdown');
            dropdown.innerHTML = '';
            
            familyMembers.forEach(member => {
                const option = document.createElement('option');
                option.value = member.id;
                option.textContent = member.name;
                if (member.id === currentUser) {
                    option.selected = true;
                }
                dropdown.appendChild(option);
            });
        }
        
        // 初始化图表
        function initializeCharts() {
            // 清洁频率图表
            const frequencyCtx = document.getElementById('frequency-chart');
            if (frequencyCtx) {
                new Chart(frequencyCtx, {
                    type: 'bar',
                    data: {
                        labels: ['周一', '周二', '周三', '周四', '周五', '周六', '周日'],
                        datasets: [{
                            label: '清洁次数',
                            data: [0, 0, 0, 0, 0, 0, 0],
                            backgroundColor: 'rgba(236, 72, 153, 0.5)',
                            borderColor: 'rgba(236, 72, 153, 1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    precision: 0
                                }
                            }
                        }
                    }
                });
            }
            
            // 清洁时长图表
            const durationCtx = document.getElementById('duration-chart');
            if (durationCtx) {
                new Chart(durationCtx, {
                    type: 'line',
                    data: {
                        labels: ['周一', '周二', '周三', '周四', '周五', '周六', '周日'],
                        datasets: [{
                            label: '清洁时长（分钟）',
                            data: [0, 0, 0, 0, 0, 0, 0],
                            borderColor: 'rgba(147, 197, 253, 1)',
                            backgroundColor: 'rgba(147, 197, 253, 0.1)',
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            }
        }
        
        // 生成智能任务推荐
        function generateTaskRecommendations() {
            const recommendations = document.getElementById('task-recommendations');
            const tasks = [
                { name: '卧室清洁', difficulty: '简单', points: 10, estimatedTime: '15分钟' },
                { name: '客厅整理', difficulty: '中等', points: 20, estimatedTime: '25分钟' },
                { name: '厨房清洁', difficulty: '挑战', points: 40, estimatedTime: '40分钟' }
            ];
            
            recommendations.innerHTML = '';
            tasks.forEach((task, index) => {
                const card = document.createElement('div');
                card.className = 'recommendation-card relative bg-white rounded-xl shadow-md p-4 border-2 border-blue-100';
                card.innerHTML = `
                    <div class="recommendation-badge">${index + 1}</div>
                    <h3 class="font-bold text-lg mb-2">${task.name}</h3>
                    <div class="flex items-center mb-2">
                        <span class="text-sm bg-blue-100 text-blue-800 px-2 py-1 rounded-full">${task.difficulty}</span>
                        <span class="text-sm text-gray-600 ml-2">${task.estimatedTime}</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-sm text-gray-600">奖励: ${task.points}经验</span>
                        <button class="bg-blue-400 hover:bg-blue-500 text-white px-3 py-1 rounded-lg text-sm transition touch-target">
                            开始
                        </button>
                    </div>
                `;
                recommendations.appendChild(card);
            });
        }
        
        // 选择任务
        function selectTask(card) {
            // 模拟任务完成
            const taskName = card.querySelector('h3').textContent;
            completeTask(taskName);
        }
        
        // 完成任务
        function completeTask(taskName) {
            // 更新用户数据
            const userIndex = familyMembers.findIndex(m => m.id === currentUser);
            if (userIndex !== -1) {
                const user = familyMembers[userIndex];
                user.contribution += 1;
                user.experience += 10;
                
                // 检查升级
                if (user.experience >= 100) {
                    user.level += 1;
                    user.experience -= 100;
                    showLevelUpAnimation();
                }
                
                // 更新成就
                updateAchievements();
                
                // 添加清洁记录
                const record = {
                    id: Date.now(),
                    user: user.id,
                    task: taskName,
                    date: new Date().toISOString(),
                    duration: Math.floor(Math.random() * 30) + 10,
                    score: Math.floor(Math.random() * 20) + 80
                };
                cleaningHistory.push(record);
                
                // 保存数据
                saveToLocalStorage();
                
                // 更新UI
                updateUI();
                
                // 显示完成提示
                alert(`任务完成！获得10经验值`);
            }
        }
        
        // 显示升级动画
        function showLevelUpAnimation() {
            const header = document.getElementById('header');
            header.classList.add('level-up-animation');
            setTimeout(() => {
                header.classList.remove('level-up-animation');
            }, 1000);
        }
        
        // 更新成就
        function updateAchievements() {
            // 初次清洁
            const firstCleanAchievement = achievements.find(a => a.id === 1);
            if (firstCleanAchievement && !firstCleanAchievement.unlocked) {
                firstCleanAchievement.progress = 1;
                firstCleanAchievement.unlocked = true;
            }
            
            // 清洁达人
            const cleaningMasterAchievement = achievements.find(a => a.id === 2);
            if (cleaningMasterAchievement) {
                const user = familyMembers.find(m => m.id === currentUser);
                if (user) {
                    cleaningMasterAchievement.progress = user.contribution;
                    if (cleaningMasterAchievement.progress >= cleaningMasterAchievement.target) {
                        cleaningMasterAchievement.unlocked = true;
                    }
                }
            }
        }
        
        // 处理图片上传
        function handleImageUpload(e, type) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const image = document.getElementById(`${type}-image`);
                    const placeholder = document.getElementById(`${type}-placeholder`);
                    image.src = e.target.result;
                    image.classList.remove('hidden');
                    placeholder.classList.add('hidden');
                };
                reader.readAsDataURL(file);
            }
        }
        
        // 生成对比图
        function generateCompare() {
            const beforeImage = document.getElementById('before-image');
            const afterImage = document.getElementById('after-image');
            const compareResult = document.getElementById('compare-result');
            const compareBefore = document.getElementById('compare-before');
            const compareAfter = document.getElementById('compare-after');
            
            if (beforeImage.src && afterImage.src) {
                compareBefore.style.backgroundImage = `url(${beforeImage.src})`;
                compareAfter.style.backgroundImage = `url(${afterImage.src})`;
                compareResult.classList.remove('hidden');
            } else {
                alert('请上传清洁前后的照片');
            }
        }
        
        // AI识别
        function aiIdentify() {
            const beforeImage = document.getElementById('before-image');
            const afterImage = document.getElementById('after-image');
            const aiResult = document.getElementById('ai-result');
            
            if (beforeImage.src && afterImage.src) {
                // 模拟AI识别
                setTimeout(() => {
                    aiResult.classList.remove('hidden');
                    
                    // 增加经验和金币
                    const userIndex = familyMembers.findIndex(m => m.id === currentUser);
                    if (userIndex !== -1) {
                        const user = familyMembers[userIndex];
                        user.experience += 100;
                        
                        // 检查升级
                        if (user.experience >= 100) {
                            user.level += 1;
                            user.experience -= 100;
                            showLevelUpAnimation();
                        }
                        
                        saveToLocalStorage();
                        updateUI();
                    }
                }, 1000);
            } else {
                alert('请上传清洁前后的照片');
            }
        }
        
        // 保存布局配置
        function saveLayout() {
            const roomType = document.getElementById('room-type').value;
            const roomSize = document.getElementById('room-size').value;
            const items = [];
            
            document.querySelectorAll('input[type="checkbox"]:checked').forEach(checkbox => {
                items.push(checkbox.id.replace('item-', ''));
            });
            
            const layout = {
                roomType,
                roomSize,
                items
            };
            
            localStorage.setItem('roomLayout', JSON.stringify(layout));
            alert('布局配置已保存');
        }
        
        // 加载演示图片
        function loadDemoImages() {
            const room = document.getElementById('demo-room').value;
            const difficulty = document.getElementById('demo-difficulty').value;
            
            // 使用SVG模拟图片
            const beforeImage = document.getElementById('before-image');
            const afterImage = document.getElementById('after-image');
            const beforePlaceholder = document.getElementById('before-placeholder');
            const afterPlaceholder = document.getElementById('after-placeholder');
            
            beforeImage.classList.add('hidden');
            afterImage.classList.add('hidden');
            beforePlaceholder.classList.remove('hidden');
            afterPlaceholder.classList.remove('hidden');
            
            // 显示模拟图片
            document.getElementById('before-placeholder').innerHTML = `
                <div class="before-clean w-full h-full rounded-lg"></div>
            `;
            
            document.getElementById('after-placeholder').innerHTML = `
                <div class="after-clean w-full h-full rounded-lg"></div>
            `;
        }
        
        // 重置演示
        function resetDemo() {
            const beforeImage = document.getElementById('before-image');
            const afterImage = document.getElementById('after-image');
            const beforePlaceholder = document.getElementById('before-placeholder');
            const afterPlaceholder = document.getElementById('after-placeholder');
            
            beforeImage.src = '';
            afterImage.src = '';
            beforeImage.classList.add('hidden');
            afterImage.classList.add('hidden');
            beforePlaceholder.classList.remove('hidden');
            afterPlaceholder.classList.remove('hidden');
            
            beforePlaceholder.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <p class="text-sm md:text-base">点击上传照片</p>
            `;
            
            afterPlaceholder.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 md:h-12 md:w-12 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <p class="text-sm md:text-base">点击上传照片</p>
            `;
        }
        
        // 筛选历史记录
        function filterHistory() {
            const dateFrom = document.getElementById('date-from').value;
            const dateTo = document.getElementById('date-to').value;
            const room = document.getElementById('history-room').value;
            const user = document.getElementById('history-user').value;
            
            const filtered = cleaningHistory.filter(record => {
                const recordDate = new Date(record.date);
                const fromDate = dateFrom ? new Date(dateFrom) : null;
                const toDate = dateTo ? new Date(dateTo) : null;
                
                const dateMatch = (!fromDate || recordDate >= fromDate) && (!toDate || recordDate <= toDate);
                const roomMatch = room === 'all' || record.task.includes(room);
                const userMatch = user === 'all' || record.user === user;
                
                return dateMatch && roomMatch && userMatch;
            });
            
            updateHistoryList(filtered);
        }
        
        // 更新历史记录列表
        function updateHistoryList(records) {
            const list = document.getElementById('cleaning-history-list');
            
            if (records.length === 0) {
                list.innerHTML = `
                    <div class="text-center text-gray-500 py-4">
                        <p>暂无清洁记录</p>
                    </div>
                `;
                return;
            }
            
            list.innerHTML = '';
            records.forEach(record => {
                const user = familyMembers.find(m => m.id === record.user);
                const user_name = user ? user.name : '未知用户';
                const date = new Date(record.date).toLocaleDateString();
                
                const item = document.createElement('div');
                item.className = 'border-b border-gray-200 pb-3 mb-3 last:border-0 last:pb-0 last:mb-0';
                item.innerHTML = `
                    <div class="flex justify-between items-center">
                        <span class="font-medium">${record.task}</span>
                        <span class="text-xs text-gray-600">${date}</span>
                    </div>
                    <div class="flex justify-between items-center text-sm text-gray-600">
                        <span>${user_name}</span>
                        <span>${record.duration}分钟</span>
                    </div>
                    <div class="mt-1">
                        <div class="w-full bg-gray-200 rounded-full h-1.5">
                            <div class="bg-green-500 h-1.5 rounded-full" style="width: ${record.score}%"></div>
                        </div>
                        <p class="text-xs text-gray-600 mt-1">整洁度: ${record.score}分</p>
                    </div>
                `;
                list.appendChild(item);
            });
        }
        
        // 发送表扬
        function sendPraise() {
            const user = document.getElementById('praise-user').value;
            const content = document.getElementById('praise-content').value;
            const userObj = familyMembers.find(m => m.id === user);
            
            if (userObj) {
                const praise = {
                    id: Date.now(),
                    from: currentUser,
                    to: user,
                    content: content,
                    date: new Date().toISOString()
                };
                
                praiseRecords.push(praise);
                saveToLocalStorage();
                updatePraiseList();
                alert('表扬已发送！');
            }
        }
        
        // 更新表扬记录列表
        function updatePraiseList() {
            const list = document.getElementById('praise-list');
            
            if (praiseRecords.length === 0) {
                list.innerHTML = `
                    <div class="text-center text-gray-500 py-4">
                        <p>暂无表扬记录</p>
                    </div>
                `;
                return;
            }
            
            list.innerHTML = '';
            praiseRecords.forEach(praise => {
                const fromUser = familyMembers.find(m => m.id === praise.from);
                const toUser = familyMembers.find(m => m.id === praise.to);
                const from_name = fromUser ? fromUser.name : '未知用户';
                const to_name = toUser ? toUser.name : '未知用户';
                const date = new Date(praise.date).toLocaleDateString();
                
                const contentMap = {
                    clean: '打扫得真干净！',
                    fast: '速度真快！',
                    thorough: '打扫得真仔细！',
                    creative: '方法真有创意！'
                };
                
                const item = document.createElement('div');
                item.className = 'border-b border-gray-200 pb-3 mb-3 last:border-0 last:pb-0 last:mb-0';
                item.innerHTML = `
                    <div class="flex justify-between items-center">
                        <span class="font-medium">${from_name} → ${to_name}</span>
                        <span class="text-xs text-gray-600">${date}</span>
                    </div>
                    <p class="text-sm text-gray-700">${contentMap[praise.content] || praise.content}</p>
                `;
                list.appendChild(item);
            });
        }
        
        // 分享到社交平台
        function shareTo(platform) {
            const url = window.location.href;
            const title = '家务勇者 - 把家务变成游戏闯关';
            const text = '我在使用家务勇者，把家务变成游戏闯关，让孩子爱上做家务！';
            
            switch (platform) {
                case 'wechat':
                    alert('请截图分享到微信');
                    break;
                case 'weibo':
                    const weiboUrl = `http://service.weibo.com/share/share.php?url=${encodeURIComponent(url)}&title=${encodeURIComponent(title)}&content=${encodeURIComponent(text)}`;
                    window.open(weiboUrl, '_blank');
                    break;
                case 'qq':
                    const qqUrl = `https://connect.qq.com/widget/shareqq/index.html?url=${encodeURIComponent(url)}&title=${encodeURIComponent(title)}&summary=${encodeURIComponent(text)}`;
                    window.open(qqUrl, '_blank');
                    break;
            }
        }
        
        // 复制链接
        function copyLink() {
            const url = window.location.href;
            navigator.clipboard.writeText(url).then(() => {
                alert('链接已复制到剪贴板');
            });
        }
        
        // 打开家庭成员模态框
        function openFamilyModal() {
            const modal = document.getElementById('family-modal');
            const list = document.getElementById('family-members-list');
            
            list.innerHTML = '';
            familyMembers.forEach(member => {
                const item = document.createElement('div');
                item.className = 'flex justify-between items-center border-b border-gray-200 pb-2 mb-2 last:border-0 last:pb-0 last:mb-0';
                item.innerHTML = `
                    <div>
                        <p class="font-medium">${member.name}</p>
                        <p class="text-xs text-gray-600">Lv.${member.level} | 贡献: ${member.contribution}</p>
                    </div>
                    <button class="delete-member text-red-500 hover:text-red-700" data-id="${member.id}" ${member.id === 'default' ? 'disabled' : ''}>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                `;
                list.appendChild(item);
            });
            
            // 添加删除成员事件
            document.querySelectorAll('.delete-member').forEach(btn => {
                if (!btn.disabled) {
                    btn.addEventListener('click', function() {
                        const id = this.getAttribute('data-id');
                        familyMembers = familyMembers.filter(m => m.id !== id);
                        openFamilyModal();
                    });
                }
            });
            
            modal.classList.remove('hidden');
        }
        
        // 关闭家庭成员模态框
        function closeFamilyModal() {
            document.getElementById('family-modal').classList.add('hidden');
        }
        
        // 添加家庭成员
        function addFamilyMember() {
            const name = document.getElementById('new-member-name').value.trim();
            if (name) {
                const newMember = {
                    id: 'member_' + Date.now(),
                    name: name,
                    contribution: 0,
                    level: 1,
                    experience: 0
                };
                familyMembers.push(newMember);
                document.getElementById('new-member-name').value = '';
                openFamilyModal();
            }
        }
        
        // 保存家庭成员
        function saveFamilyMembers() {
            saveToLocalStorage();
            updateUserDropdown();
            closeFamilyModal();
            alert('家庭成员已保存');
        }
        
        // 打开排行榜模态框
        function openLeaderboardModal() {
            const modal = document.getElementById('leaderboard-modal');
            const list = document.getElementById('leaderboard-list');
            
            // 按贡献排序
            const sortedMembers = [...familyMembers].sort((a, b) => b.contribution - a.contribution);
            
            list.innerHTML = '';
            sortedMembers.forEach((member, index) => {
                const item = document.createElement('div');
                item.className = `flex items-center p-3 mb-2 rounded-lg ${index < 3 ? 'bg-yellow-50' : 'bg-gray-50'}`;
                item.innerHTML = `
                    <div class="w-8 h-8 rounded-full flex items-center justify-center mr-3 ${index === 0 ? 'bg-yellow-400' : index === 1 ? 'bg-gray-300' : index === 2 ? 'bg-amber-700' : 'bg-gray-200'} text-white font-bold">
                        ${index + 1}
                    </div>
                    <div class="flex-1">
                        <p class="font-medium">${member.name}</p>
                        <p class="text-xs text-gray-600">Lv.${member.level} | 经验: ${member.experience}/100</p>
                    </div>
                    <div class="text-right">
                        <p class="font-bold">${member.contribution}</p>
                        <p class="text-xs text-gray-600">贡献值</p>
                    </div>
                `;
                list.appendChild(item);
            });
            
            modal.classList.remove('hidden');
        }
        
        // 关闭排行榜模态框
        function closeLeaderboardModal() {
            document.getElementById('leaderboard-modal').classList.add('hidden');
        }
        
        // 打开任务分配模态框
        function openAssignModal(card) {
            const modal = document.getElementById('assign-modal');
            const select = document.getElementById('assign-member');
            
            select.innerHTML = '';
            familyMembers.forEach(member => {
                const option = document.createElement('option');
                option.value = member.id;
                option.textContent = member.name;
                select.appendChild(option);
            });
            
            // 存储当前任务卡片
            modal.dataset.taskCard = card;
            modal.classList.remove('hidden');
        }
        
        // 关闭任务分配模态框
        function closeAssignModal() {
            document.getElementById('assign-modal').classList.add('hidden');
        }
        
        // 分配任务
        function assignTask() {
            const modal = document.getElementById('assign-modal');
            const card = modal.dataset.taskCard;
            const memberId = document.getElementById('assign-member').value;
            const member = familyMembers.find(m => m.id === memberId);
            
            if (card && member) {
                // 显示分配信息
                const statusDiv = card.querySelector('div.text-xs');
                statusDiv.textContent = `分配给: ${member.name}`;
                statusDiv.className = 'text-xs bg-blue-100 text-blue-800 px-2 py-1 rounded-full inline-block';
                
                closeAssignModal();
            }
        }
        
        // 取消分配
        function unassignTask() {
            const modal = document.getElementById('assign-modal');
            const card = modal.dataset.taskCard;
            
            if (card) {
                const statusDiv = card.querySelector('div.text-xs');
                statusDiv.textContent = '未完成';
                statusDiv.className = 'text-xs bg-gray-100 text-gray-800 px-2 py-1 rounded-full inline-block';
                
                closeAssignModal();
            }
        }
        
        // 更新UI
        function updateUI() {
            // 更新用户信息
            const user = familyMembers.find(m => m.id === currentUser);
            if (user) {
                // 更新等级
                const levelElement = document.querySelector('.bg-yellow-400');
                if (levelElement) {
                    levelElement.textContent = `Lv.${user.level}`;
                }
                
                // 更新称号
                const titleElement = document.querySelector('header .hidden span');
                if (titleElement) {
                    const titles = ['见习家务勇者', '初级家务勇者', '中级家务勇者', '高级家务勇者', '家务大师'];
                    const titleIndex = Math.min(Math.floor(user.level / 2), titles.length - 1);
                    titleElement.textContent = titles[titleIndex];
                }
                
                // 更新经验条
                const experienceElement = document.querySelector('.bg-gradient-to-r.from-pink-400.to-purple-400');
                if (experienceElement) {
                    experienceElement.style.width = `${(user.experience / 100) * 100}%`;
                }
                
                // 更新经验值文本
                const experienceText = document.querySelector('.text-xs.text-gray-600');
                if (experienceText) {
                    experienceText.textContent = `经验值: ${user.experience}/100`;
                }
                
                // 更新统计数据
                const stats = document.querySelectorAll('.grid.grid-cols-2 .text-xl.font-bold');
                if (stats.length >= 4) {
                    stats[0].textContent = user.contribution;
                    stats[1].textContent = '0分钟'; // 总时长需要计算
                    stats[2].textContent = user.contribution * 10;
                    stats[3].textContent = achievements.filter(a => a.unlocked).length;
                }
            }
            
            // 更新历史记录
            updateHistoryList(cleaningHistory);
            
            // 更新表扬记录
            updatePraiseList();
        }
    </script>
</body>
</html>